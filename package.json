    "expo-build-properties": "~55.0.14",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-dev-client": "~55.0.35",
    "expo-device": "~55.0.17",
    "expo-file-system": "~55.0.21",
    "expo-font": "~55.0.8",
    "expo-glass-effect": "~55.0.11",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.10",
    "expo-image-picker": "~55.0.20",
    "expo-insights": "~55.0.17",
    "expo-keep-awake": "~55.0.8",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-local-authentication": "~55.0.14",
    "expo-manifests": "~55.0.17",
    "expo-network": "~55.0.14",
    "expo-notifications": "~55.0.23",
    "expo-print": "~55.0.17",
    "expo-router": "~55.0.15",
    "expo-secure-store": "~55.0.14",
    "expo-sharing": "~55.0.19",
    "expo-speech": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.9",
    "expo-system-ui": "~55.0.18",
    "expo-updates": "~55.0.23",
    "expo-web-browser": "~55.0.16",
    "hono": "4.6.0",
    "jszip": "^3.10.1",
    "lottie-react-native": "~7.3.4",
    "lucide-react-native": "^1.16.0",
    "nativewind": "~4.1.23",
    "patch-package": "^8.0.0",
    "pretty-format": "^29.7.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-edge-to-edge": "1.6.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-mmkv": "^3.2.0",
    "react-native-pager-view": "8.0.0",
    "react-native-purchases": "^10.2.2",
    "react-native-purchases-ui": "^10.2.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4",
    "reanimated-tab-view": "^0.4.0",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2",
    "uuid": "^11.1.0",
    "yaml": "^2.9.0",
    "zod": "4.1.11",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@tanstack/eslint-plugin-query": "^5.62.10",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "~29.5.14",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.18",
    "prettier": "^3.3.3",
    "react-native-svg-transformer": "^1.5.1",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "expo-asset",
        "expo-av"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@babel/plugin-proposal-export-namespace-from",
          "patch-package",
          "pretty-format",
          "reanimated-tab-view",
          "uuid",
          "expo-av"
        ]
      }
    }
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|zustand)"
    ],
    "setupFiles": [],
    "coverageDirectory": "test_reports/coverage"
  },
  "private": true,
  "overrides": {
    "react-native-css-interop": "0.1.22"
  },
  "patchedDependencies": {
    "reanimated-tab-view@0.4.0": "patches/reanimated-tab-view@0.4.0.patch"
  }
}
