{
  "name": "vocolens",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "postinstall": "node scripts/write-env.js",
    "start": "RCT_METRO_PORT=8084 EXPO_NO_PROMPT=1 npx expo start",
    "tunnel": "RCT_METRO_PORT=8084 EXPO_NO_PROMPT=1 npx expo start --tunnel --clear",
    "lan": "RCT_METRO_PORT=8084 EXPO_NO_PROMPT=1 npx expo start --lan --clear",
    "android": "RCT_METRO_PORT=8084 EXPO_NO_PROMPT=1 npx expo start --android",
    "ios": "RCT_METRO_PORT=8084 EXPO_NO_PROMPT=1 npx expo start --ios",
    "web": "RCT_METRO_PORT=8084 EXPO_NO_PROMPT=1 npx expo start --web --clear",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@expo-google-fonts/comfortaa": "^0.4.2",
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/html-elements": "^0.13.7",
    "@expo/metro-runtime": "~55.0.11",
    "@expo/react-native-action-sheet": "^4.1.1",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/native": "^7.1.6",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "5.90.2",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.10",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo": "~55.0.25",
    "expo-application": "~55.0.15",
    "expo-asset": "~55.0.17",
